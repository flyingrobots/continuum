{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wesley.dev/schemas/ttd-ir.schema.json",
  "title": "TTD IR Schema",
  "description": "Intermediate Representation for the Continuum-owned Wesley TTD compiler module. Consumed by external code generators.",
  "type": "object",
  "required": ["ir_version", "schema_sha256", "generated_by"],
  "properties": {
    "ir_version": {
      "type": "string",
      "const": "ttd-ir/v1",
      "description": "IR schema version tag"
    },
    "schema_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 hash of the normalized source GraphQL schema"
    },
    "generated_by": {
      "type": "object",
      "required": ["tool"],
      "properties": {
        "tool": {
          "type": "string",
          "description": "Tool name that generated this IR"
        },
        "version": {
          "type": "string",
          "description": "Tool version"
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "extractedAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when IR was extracted"
        },
        "ttdVersion": {
          "type": "string",
          "description": "TTD specification version"
        }
      }
    },
    "channels": {
      "type": "array",
      "description": "Message channels for event routing",
      "items": {
        "$ref": "#/$defs/Channel"
      }
    },
    "ops": {
      "type": "array",
      "description": "Operations (mutations and queries)",
      "items": {
        "$ref": "#/$defs/Op"
      }
    },
    "rules": {
      "type": "array",
      "description": "State transition rules",
      "items": {
        "$ref": "#/$defs/Rule"
      }
    },
    "invariants": {
      "type": "array",
      "description": "System invariants (laws)",
      "items": {
        "$ref": "#/$defs/Invariant"
      }
    },
    "emissions": {
      "type": "array",
      "description": "Emission contracts (op -> channel)",
      "items": {
        "$ref": "#/$defs/Emission"
      }
    },
    "footprints": {
      "type": "array",
      "description": "Resource footprints for operations",
      "items": {
        "$ref": "#/$defs/Footprint"
      }
    },
    "registry": {
      "type": "array",
      "description": "Type registry entries with stable IDs",
      "items": {
        "$ref": "#/$defs/RegistryEntry"
      }
    },
    "codecs": {
      "type": "array",
      "description": "Codec specifications for types",
      "items": {
        "$ref": "#/$defs/CodecSpec"
      }
    },
    "types": {
      "type": "array",
      "description": "Object type definitions",
      "items": {
        "$ref": "#/$defs/TypeDef"
      }
    },
    "enums": {
      "type": "array",
      "description": "Enum type definitions",
      "items": {
        "$ref": "#/$defs/EnumDef"
      }
    }
  },
  "$defs": {
    "Channel": {
      "type": "object",
      "required": ["kind", "name", "version", "eventTypes"],
      "properties": {
        "kind": { "const": "CHANNEL" },
        "name": { "type": "string" },
        "version": { "type": "integer", "minimum": 1 },
        "eventTypes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ordered": { "type": "boolean", "default": true },
        "persistent": { "type": "boolean", "default": false }
      }
    },
    "Op": {
      "type": "object",
      "required": ["kind", "name", "op_id", "args", "resultType"],
      "properties": {
        "kind": { "const": "OP" },
        "name": { "type": "string" },
        "op_id": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4294967295,
          "description": "Stable 32-bit operation ID (hash of namespace:name)"
        },
        "args": {
          "type": "array",
          "items": { "$ref": "#/$defs/Arg" }
        },
        "resultType": { "type": "string" },
        "idempotent": { "type": "boolean", "default": false },
        "readonly": { "type": "boolean", "default": false },
        "timeout": { "type": "integer", "minimum": 0 },
        "rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/Rule" },
          "description": "Transition rules attached to this op"
        }
      }
    },
    "Arg": {
      "type": "object",
      "required": ["name", "type", "required"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "required": { "type": "boolean" },
        "list": { "type": "boolean", "default": false }
      }
    },
    "Rule": {
      "type": "object",
      "required": ["kind", "name", "from", "to"],
      "properties": {
        "kind": { "const": "RULE" },
        "name": { "type": "string" },
        "from": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Source states"
        },
        "to": {
          "type": "string",
          "description": "Target state"
        },
        "guard": {
          "type": "string",
          "description": "Guard expression (optional)"
        },
        "opName": {
          "type": "string",
          "description": "Operation this rule is attached to"
        }
      }
    },
    "Invariant": {
      "type": "object",
      "required": ["kind", "name", "expr"],
      "properties": {
        "kind": { "const": "INVARIANT" },
        "name": { "type": "string" },
        "expr": {
          "type": "string",
          "description": "Invariant expression in TTD expression language"
        },
        "severity": {
          "type": "string",
          "enum": ["error", "warning"],
          "default": "error"
        }
      }
    },
    "Emission": {
      "type": "object",
      "required": ["kind", "channel", "opName"],
      "properties": {
        "kind": { "const": "EMISSION" },
        "channel": { "type": "string" },
        "event": { "type": "string" },
        "opName": { "type": "string" },
        "condition": { "type": "string" },
        "withinMs": {
          "type": "integer",
          "minimum": 0,
          "description": "Max delay in milliseconds"
        }
      }
    },
    "Footprint": {
      "type": "object",
      "required": ["kind", "opName"],
      "properties": {
        "kind": { "const": "FOOTPRINT" },
        "opName": { "type": "string" },
        "reads": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "writes": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "creates": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "deletes": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "slots": {
          "type": "array",
          "items": { "$ref": "#/$defs/FootprintSlot" },
          "default": []
        },
        "closures": {
          "type": "array",
          "items": { "$ref": "#/$defs/FootprintClosure" },
          "default": []
        },
        "createSlots": {
          "type": "array",
          "items": { "$ref": "#/$defs/FootprintCreateSlot" },
          "default": []
        },
        "updates": {
          "type": "array",
          "items": { "$ref": "#/$defs/FootprintUpdate" },
          "default": []
        },
        "forbids": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "FootprintSlot": {
      "type": "object",
      "required": ["slot", "kind", "access"],
      "properties": {
        "slot": { "type": "string" },
        "kind": { "type": "string" },
        "bindFromArg": { "type": "string" },
        "bindFromSlot": { "type": "string" },
        "bindRelation": { "type": "string" },
        "access": {
          "type": "array",
          "items": { "type": "string", "enum": ["READ", "WRITE", "DELETE"] }
        },
        "cardinality": {
          "type": "string",
          "enum": ["ONE", "OPTIONAL", "MANY"],
          "default": "ONE"
        }
      }
    },
    "FootprintClosure": {
      "type": "object",
      "required": ["slot", "fromSlot", "operator", "reads"],
      "properties": {
        "slot": { "type": "string" },
        "fromSlot": { "type": "string" },
        "operator": { "type": "string" },
        "argBindings": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "reads": {
          "type": "array",
          "items": { "type": "string" }
        },
        "cardinality": {
          "type": "string",
          "enum": ["ONE", "OPTIONAL", "MANY"],
          "default": "MANY"
        }
      }
    },
    "FootprintCreateSlot": {
      "type": "object",
      "required": ["slot", "kind"],
      "properties": {
        "slot": { "type": "string" },
        "kind": { "type": "string" },
        "cardinality": {
          "type": "string",
          "enum": ["ONE", "OPTIONAL", "MANY"],
          "default": "ONE"
        }
      }
    },
    "FootprintUpdate": {
      "type": "object",
      "required": ["slot", "fields"],
      "properties": {
        "slot": { "type": "string" },
        "fields": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "RegistryEntry": {
      "type": "object",
      "required": ["kind", "typeName", "id"],
      "properties": {
        "kind": { "const": "REGISTRY_ENTRY" },
        "typeName": { "type": "string" },
        "id": {
          "type": "integer",
          "minimum": 0,
          "description": "Stable type ID for serialization"
        },
        "deprecated": { "type": "boolean", "default": false },
        "deprecatedBy": { "type": "string" }
      }
    },
    "CodecSpec": {
      "type": "object",
      "required": ["kind", "typeName", "format"],
      "properties": {
        "kind": { "const": "CODEC" },
        "typeName": { "type": "string" },
        "format": {
          "type": "string",
          "enum": ["cbor", "json", "protobuf"]
        },
        "canonical": {
          "type": "boolean",
          "default": true,
          "description": "Use canonical encoding (sorted keys for CBOR)"
        }
      }
    },
    "TypeDef": {
      "type": "object",
      "required": ["name", "fields"],
      "properties": {
        "name": { "type": "string" },
        "version": {
          "type": "object",
          "properties": {
            "major": { "type": "integer" },
            "minor": { "type": "integer" },
            "patch": { "type": "integer", "default": 0 }
          }
        },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/FieldDef" }
        }
      }
    },
    "FieldDef": {
      "type": "object",
      "required": ["name", "type", "required"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "required": { "type": "boolean" },
        "list": { "type": "boolean", "default": false },
        "stateField": {
          "type": "object",
          "properties": {
            "key": { "type": "boolean", "default": false },
            "derived": { "type": "boolean", "default": false },
            "derivation": { "type": "string" }
          }
        },
        "constraint": {
          "type": "object",
          "properties": {
            "min": { "type": "integer" },
            "max": { "type": "integer" },
            "minLength": { "type": "integer" },
            "maxLength": { "type": "integer" },
            "pattern": { "type": "string" },
            "oneOf": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "EnumDef": {
      "type": "object",
      "required": ["name", "values"],
      "properties": {
        "name": { "type": "string" },
        "values": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
